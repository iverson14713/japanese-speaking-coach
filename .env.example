# OpenAI API key for AI Coach (set in Vercel project Environment Variables)
OPENAI_API_KEY=

# Optional: override default model (gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Frontend API path (default /coach, rewritten to /api/coach on Vercel)
# VITE_AI_API_BASE=/coach

# Use local mock responses instead of calling the coach API (dev only)
# VITE_AI_COACH_USE_MOCK=true

# On API failure, fall back to mock and show AI Source: Fallback in debug mode
# VITE_AI_COACH_FALLBACK_ON_ERROR=true
