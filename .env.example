# OpenAI API key for AI Coach (set in Vercel project Environment Variables)
OPENAI_API_KEY=

# Optional: override default model (gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Frontend: API base path (production default is /coach via vercel.json rewrite)
# VITE_AI_API_BASE=/coach

# Force local mock mode during development
# VITE_AI_API_BASE=
